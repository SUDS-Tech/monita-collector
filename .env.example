# Copy this file to .env and fill in the values
# cp .env.example .env

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
APP_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL 15+ connection string
# Neon: copy the "Pooled connection" string from your project dashboard
DB_URL=postgres://user:password@host/dbname?sslmode=require
DB_MAX_CONNS=25

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=

# ── Stripe (optional — billing not yet active) ────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
